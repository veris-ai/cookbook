# HolmesGPT LLM provider — set ONE
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Override the default model. Examples:
#   openai/gpt-5.4-mini
#   openai/gpt-5.4
#   anthropic/claude-sonnet-4-5-20250929
MODEL=openai/gpt-5.4-mini

# PagerDuty (Source — Python fetches incident + writes analysis note back)
PAGERDUTY_API_TOKEN=
PAGERDUTY_USER_EMAIL=sre-bot@holmesgpt.local

# Datadog (Toolset — the LLM calls fetch_datadog_logs / query_datadog_metrics)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_API_URL=https://api.datadoghq.com
