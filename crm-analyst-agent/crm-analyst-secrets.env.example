# crm-analyst-agent build secrets — copy to `crm-analyst-secrets.env` and fill in.
# The overlay Dockerfile COPYs `crm-analyst-secrets.env` at build time to bake:
#   - the Langfuse OTLP auth header into openclaw.json
#   - the PostHog creds into /sandbox/.secrets/posthog.env (a non-state_dir path)
# DO NOT COMMIT the filled-in file (see .gitignore).

# Langfuse Cloud (US region) — for the OTLP trace auth header
LANGFUSE_PUBLIC_KEY=pk-lf-XXXXXXXX
LANGFUSE_SECRET_KEY=sk-lf-XXXXXXXX
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# PostHog (US cloud) — Personal API key with query:read + person:read
POSTHOG_API_KEY=phx_XXXXXXXX
POSTHOG_API_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=<your-project-id>
