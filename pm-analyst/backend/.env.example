# Server
PORT=8000

# Google AI — use one of the following:
GOOGLE_API_KEY=                  # Google AI Studio key
GCP_PROJECT=                     # GCP project (for Vertex AI)
GCP_LOCATION=global              # Vertex AI region
ADK_MODEL=gemini-2.5-flash

# Microsoft Entra ID (required for Teams + OneDrive integration)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# Azure DevOps (optional — required for creating work items)
ADO_ORG=
ADO_PROJECT=

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:3000
