# ─── GCP / Vertex AI ───
# Option A: Vertex AI (service account)
GCP_PROJECT=REPLACE_ME
GCP_LOCATION=global
# Either point GOOGLE_APPLICATION_CREDENTIALS to a key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa-key.json
# Or pass the key JSON inline (e.g. from a secret manager):
GCP_SERVICE_ACCOUNT_JSON=REPLACE_ME

# Option B: Google AI Studio API key (no RAG support)
# GOOGLE_API_KEY=your-api-key

# ─── Agent Config ───
ADK_MODEL=gemini-2.5-flash

# ─── Vertex AI RAG ───
RAG_CORPUS_ID=REPLACE_ME
RAG_LOCATION=europe-west4

# ─── Hogan API ───
HOGAN_API_BASE_URL=https://api.hogan.dxc.com
