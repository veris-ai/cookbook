# Extends veris-gvisor base with your agent code
ARG VERIS_BASE
FROM ${VERIS_BASE}

# Copy dependency manifests first (Docker layer caching)
COPY pyproject.toml uv.lock README.md /agent/

# Install dependencies
WORKDIR /agent
RUN uv sync --frozen --no-dev

# Copy agent source code
COPY app/ /agent/app/

# Required by veris
WORKDIR /app
